generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  name           String
  avatarUrl      String?
  pushToken      String?
  neighborhoodId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  neighborhood      Neighborhood?       @relation(fields: [neighborhoodId], references: [id])
  bills             Bill[]
  leaderboardEntries MonthlyLeaderboard[]
  notificationLogs  NotificationLog[]
  refreshTokens     RefreshToken[]
}

model Neighborhood {
  id         String   @id @default(cuid())
  name       String
  city       String
  postalCode String
  boundary   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users              User[]
  leaderboardEntries MonthlyLeaderboard[]
}

model Bill {
  id               String      @id @default(cuid())
  userId           String
  type             BillType
  rawImageUrl      String?
  address          String
  subscriberNumber String
  periodStart      DateTime
  periodEnd        DateTime
  usage            Float
  co2Kg            Float
  treesSaved       Float?
  month            Int
  year             Int
  isConfirmed      Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, month, year])
}

model MonthlyLeaderboard {
  id               String   @id @default(cuid())
  userId           String
  neighborhoodId   String
  month            Int
  year             Int
  totalCo2Kg       Float
  treesSaved       Float
  rank             Int?
  neighborhoodRank Int?
  createdAt        DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  neighborhood Neighborhood @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}

model NotificationLog {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  sentAt    DateTime         @default(now())
  month     Int
  year      Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, month, year])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum BillType {
  ELECTRICITY
  GAS
}

enum NotificationType {
  BILL_REMINDER
  LEADERBOARD_RESULT
  WELCOME
}
