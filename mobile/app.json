{
  "expo": {
    "name": "EcoNeighbour",
    "slug": "econeighbour",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "econeighbour",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Faturanı fotoğraflamak için kameraya ihtiyacımız var.",
        "NSPhotoLibraryUsageDescription": "Galeriden fatura seçmek için fotoğraf kitaplığına ihtiyacımız var."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#070E0A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Faturanı fotoğraflamak için kameraya ihtiyacımız var."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Galeriden fatura seçmek için fotoğraf kitaplığına ihtiyacımız var."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#6b7d5c",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#070E0A",
          "dark": {
            "backgroundColor": "#070E0A"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "BURAYA_EAS_PROJECT_ID_EKLE"
      }
    }
  }
}
